# OKX API 配置
# 从 OKX 官网获取: https://www.okx.com/account/my-api
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_api_secret_here
OKX_PASSPHRASE=your_passphrase_here

# LunarCrush API 配置（可选）
# 用于社交媒体情绪分析
LUNARCRUSH_API_KEY=your_lunarcrush_api_key_here

# 交易配置（可选，使用默认值）
# MAX_POSITIONS=5
# MAX_DAILY_BUY=1000
# SINGLE_TRADE_AMOUNT=40

# 环境设置
NODE_ENV=production
